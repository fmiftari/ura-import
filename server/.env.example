PORT=8787
# Required for /api/v1/consumers (onboarding new partners/government keys).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# Where data/db.json is stored. Defaults to ./data next to src/ if unset.
DATA_DIR=

# Comma-separated extra origins allowed to call this API from a browser,
# beyond the built-in https://fmiftari.github.io. E.g. a partner's own site:
# EXTRA_CORS_ORIGINS=https://ganitransport.ch,https://www.bkt.com.al
EXTRA_CORS_ORIGINS=
